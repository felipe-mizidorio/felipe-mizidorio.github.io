---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const projects = (await getCollection("projects"))
    .filter((project) => !project.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Projects | Felipe Mizidorio" description="My projects.">
    <Header />
    <main class="mx-auto max-w-3x1 px-6 py-20">
        <h1 class="text-3x1 font-bold">Projects</h1>
        
        {projects.length === 0 && (
            <p class="mt-8 text-zinc-400">No projects published.</p>
        )}
    
        <ul class="mt-8 space-y-8">
            {projects.map((project) => (
                <li>
                    <a href={`/projects/${project.id}`} class="group block">
                        <h2 class="text-x1 font-semibold group-hover:text-primary-400 transition-colors">
                            {project.data.title}
                        </h2>
                        <p class="mt-1 text-zinc-400 [.light_&]:text-zinc-600">
                            {project.data.description}
                        </p>
                        <div class="mt-2 flex flex-wrap gap-2">
                            {project.data.technologies.map((tech) => (
                                <span class="rounded-full bg-zinc-800 [.light_&]:bg-zinc-100 px-3 py-1 text-xs text-zinc-300 [.light_&]:text-zinc-600">
                                    {tech}
                                </span>
                            ))}
                        </div>
                    </a>
                </li>
            ))}
        </ul>
    </main>
    <Footer />
</BaseLayout>