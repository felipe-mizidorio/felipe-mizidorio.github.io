---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog | Felipe Mizidorio" description="Papers and research">
    <Header />
    <main class="mx-auto max-w-3x1 px-6 py-20">
        <h1 class="text-3x1 font-bold">Blog</h1>

        {posts.length === 0 && (
            <p class="mt-8 text-zinc-400">No published papers.</p>
        )}

        <ul class="mt-8 space-y-8">
            {posts.map((post) => (
                <li>
                    <a href={`/blog/${post.id}`} class="group block">
                        <time
                            datetime={post.data.pubDate.toISOString()}
                            class="text-sm text-zinc-500"
                        >
                            {post.data.pubDate.toLocaleDateString("pt-BR", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                            })}
                        </time>
                        <h2 class="mt-1 text-x1 font-semibold group-hover:text-primary-400 transition-colors">
                            {post.data.title}
                        </h2>
                        <p class="mt-1 text-zinc-400 [.light_&]:text-zinc-600">
                            {post.data.description}
                        </p>
                    </a>
                </li>
            ))}
        </ul>
    </main>
    <Footer />
</BaseLayout>