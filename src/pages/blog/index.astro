---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog | Felipe Mizidorio" description="Papers and research">
    <Header />
    <main class="mx-auto max-w-3xl px-6 py-20">
        <h1 class="text-3xl font-bold">Blog</h1>
        <p class="mt-2 text-zinc-400 [.light_&]:text-zinc-600">
            Papers about technology, studies and research.
        </p>

        {posts.length === 0 && (
            <p class="mt-8 text-zinc-400">No published papers.</p>
        )}

        <ul class="mt-12 divide-y divide-zinc-800 [.light_&]:divide-zinc-200">
            {posts.map((post) => (
                <li class="py-6 first:pt-0">
                    <a href={`/blog/${post.id}`} class="group block">
                        <div class="flex items-baseline justify-between gap-4">
                            <h2 class="mt-1 text-xl font-semibold group-hover:text-accent transition-colors">
                                {post.data.title}
                            </h2>
                            <time
                                datetime={post.data.pubDate.toISOString()}
                                class="text-sm text-zinc-500"
                            >
                                {post.data.pubDate.toLocaleDateString("en-EU", {
                                    year: "numeric",
                                    month: "long",
                                    day: "numeric",
                                })}
                            </time>
                        </div>
                        <p class="mt-1 text-zinc-400 [.light_&]:text-zinc-600">
                            {post.data.description}
                        </p>
                        {post.data.tags.length > 0 && (
                            <div class="mt-2 flex gap-2">
                                {post.data.tags.map((tag) => (
                                    <span class="text-xs text-zinc-500">#{tag}</span>
                                ))}
                            </div>
                        )}
                    </a>
                </li>
            ))}
        </ul>
    </main>
    <Footer />
</BaseLayout>