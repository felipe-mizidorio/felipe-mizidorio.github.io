---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Felipe Mizidorio">
	<Header />
		<main class="mx-auto max-w-3x1 px-6 py-20">
			<h1 class="text-4x1 font-bold">Hello, I'm Felipe!</h1>
			<p class="mt-4 text-lg text-zinc-400 [.light_&]:text-zinc-600">
				Welcome to my personal workspace. Here I share papers, projects and research.
			</p>
		</main>
	<Footer />
</BaseLayout>
