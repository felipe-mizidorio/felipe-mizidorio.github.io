---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const featuredProjects = (await getCollection("projects"))
	.filter((project) => !project.data.draft && project.data.featured)
	.slice(0, 2);

const recentPosts = (await getCollection("blog"))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const stack = [
	{ name: "Python", icon: "python" },
	{ name: "PyTorch", icon: "pytorch" },
	{ name: "Scikit-Learn", icon: "scikitlearn" }, 
	{ name: "Pandas", icon: "pandas" },
	{ name: "Unity", icon: "unity" },
	{ name: "ML-Agents", icon: null }
]
---

<BaseLayout
	title="Felipe Merenda Izidorio"
	description="Research Fellow at CeDRI, Instituto Politécnico de Bragança. AI researcher focused on ML systems, reinforcement learning, multi-agent systems, and intelligent robotics."
>
	<Header />
		<main class="mx-auto max-w-3xl px-6">
			<section class="py-20">
				<div class="flex items-start justify-between gap-8">
					<div class="flex-1">
						<h1 class="text-4xl font-bold leading-tight tracking-tight">
							Felipe Merenda Izidorio
						</h1>
						<p class="mt-1 text-sm text-zinc-400 [.light_&]:text-zinc-600">
							Research Fellow · CeDRI, Instituto Politécnico de Bragança
						</p>
						<p class="mt-5 max-w-lg leading-relaxed text-zinc-400 [.light_&]:text-zinc-600">
							Research Fellow at IPB, Portugal. I work on Machine Learning and AI research, with a focus on applied ML systems and MLOps. I also explore reinforcement learning and multi-agent systems as part of my research work. Here I write about what I'm learning, share projects, and document the process.
						</p>
		
						<div class="mt-6 space-y-3 border-l border-zinc-700 pl-4 [.light_&]:border-zinc-300">
							<div class="flex items-start justify-between gap-4">
								<div>
									<p class="text-sm font-medium">M.Sc. in Informatics</p>
									<p class="text-xs text-zinc-500">IPB · Instituto Politécnico de Bragança</p>
								</div>
								<span class="shrink-0 text-xs text-zinc-500">2024 – 2025</span>
							</div>
							<div class="flex items-start justify-between gap-4">
								<div>
									<p class="text-sm font-medium">B.Sc. in Computer Science</p>
									<p class="text-xs text-zinc-500">UTFPR · Universidade Tecnológica Federal do Paraná</p>
								</div>
								<span class="shrink-0 text-xs text-zinc-500">2021 – 2025</span>
							</div>
						</div>
		
						<div class="mt-6 flex flex-wrap gap-4">
							<a
								href="https://github.com/felipe-mizidorio"
								target="_blank"
								rel="noopener noreferrer"
								class="flex items-center gap-1.5 rounded-full border border-zinc-700 px-3 py-1 text-sm text-zinc-400 transition-colors hover:text-zinc-100 [.light_&]:border-zinc-200 [.light_&]:text-zinc-600 [.light_&]:hover:text-zinc-900"
							>
								<img
									src={`https://cdn.simpleicons.org/github/a1a1aa`}
									alt=""
									class="h-4 w-4 invert dark:invert-0"
								/>
								GitHub
							</a>
							<a
								href="https://www.linkedin.com/in/felipe-merenda-izidorio/"
								target="_blank"
								rel="noopener noreferrer"
								class="flex items-center gap-1.5 rounded-full border border-zinc-700 px-3 py-1 text-sm text-zinc-400 transition-colors hover:text-zinc-100 [.light_&]:border-zinc-200 [.light_&]:text-zinc-600 [.light_&]:hover:text-zinc-900"
							>
								<svg
									role="img"
									viewBox="0 0 24 24"
									class="h-4 w-4 fill-zinc-400"
									aria-hidden="true"
								>
									<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
								</svg>
								LinkedIn
							</a>
							<a
								href="mailto:felipemerenda1@gmail.com"
								class="flex items-center gap-1.5 rounded-full border border-zinc-700 px-3 py-1 text-sm text-zinc-400 transition-colors hover:text-zinc-100 [.light_&]:border-zinc-200 [.light_&]:text-zinc-600 [.light_&]:hover:text-zinc-900"
							>
								<img
									src={`https://cdn.simpleicons.org/gmail/a1a1aa`}
									alt=""
									class="h-4 w-4 invert dark:invert-0"
								/>
								Email
							</a>
						</div>
		
						<div class="mt-6 flex gap-4">
							<a
								href="/blog"
								class="text-sm font-medium text-accent hover:text-accent-hover transition-colors"
							>
								Read blog &rarr;
							</a>
							<a
								href="/projects"
								class="text-sm font-medium text-zinc-400 hover:text-zinc-100 [.light_&]:hover:text-zinc-900 transition-colors"
							>
								View projects
							</a>
						</div>
					</div>
	
					<img
						src="/images/avatar.jpeg"
						alt="Felipe Merenda Izidorio"
						class="hidden sm:flex h-24 w-24 shrink-0 items-center justify-center rounded-full bg-zinc-800 text-lg font-bold text-zinc-500 [.light_&]:bg-zinc-100">
					</img>
				</div>
			</section>

			<section class="border-t border-zinc-800 py-16 [.light_&]:border-zinc-200">
				<h2 class="text-xs font-medium uppercase tracking-widest text-zinc-500">
					Tools &amp; Technologies
				</h2>
				<div class="mt-5 flex flex-wrap gap-2">
					{stack.map((tech) => (
						<span class="flex items-center gap-1.5 rounded-full border border-zinc-700 px-3 py-1 text-sm text-zinc-400 [.light_&]:border-zinc-200 [.light_&]:text-zinc-600">
							{tech.icon && (
								<img
									src={`https://cdn.simpleicons.org/${tech.icon}/a1a1aa`}
									alt={tech.name}
									class="h-4 w-4 invert dark:invert-0"
								/>
							)}
							{tech.name}
						</span>
					))}
				</div>
			</section>

			{featuredProjects.length > 0 && (
				<section class="border-t border-zinc-800 [.light_&]:border-zinc-200 py-16">
					<h2 class="text-sm font-medium uppercase tracking-widest text-zinc-500">
						Featured projects
					</h2>
					<ul class="mt-8 space-y-8">
						{featuredProjects.map((project) => (
							<li>
								<a href={`/projects/${project.id}`} class="group block">
									<h3 class="font-medium group-hover:text-accent transition-colors">
										{project.data.title}
									</h3>
									<p class="mt-1 text-sm text-zinc-400 [.light_&]:text-zinc-600">
										{project.data.description}
									</p>
									<div class="mt-3 flex flex-wrap gap-2">
										{project.data.technologies.map((tech) => (
											<span class="rounded-full border border-zinc-700 px-3 py-1 text-xs text-zinc-400 [.light_&]:border-zinc-200 [.light_&]:text-zinc-600">
												{tech}
											</span>
										))}
									</div>
									<div class="mt-3 flex gap-4 text-sm">
										{project.data.repoUrl && (
											<span class="text-zinc-500">Repository &#x2197;</span>
										)}
										{project.data.liveUrl && (
											<span class="text-zinc-500">Demo &#x2197;</span>
										)}
									</div>
								</a>
							</li>
						))}
					</ul>
					<a
						href="/projects"
						class="mt-8 block text-sm text-zinc-500 transition-colors hover:text-zinc-300 [.light_&]:hover:text-zinc-700"
					>
						All projects &rarr;
					</a>
				</section>
			)}

			{recentPosts.length > 0 && (
				<section class="border-t border-zinc-800 [.light_&]:border-zinc-200 py-16">
					<h2 class="text-sm font-medium uppercase tracking-widest text-zinc-500">
						Recent articles
					</h2>
					<ul class="mt-8 space-y-6">
						{recentPosts.map((post) => (
							<li>
								<a href={`/blog/${post.id}`} class="group block">
									<div class="flex items-baseline justify-between gap-4">
										<h3 class="font-medium group-hover:text-accent transition-colors">
											{post.data.title}
										</h3>
										<time
											datetime={post.data.pubDate.toISOString()}
											class="shrink-0 text-sm text-zinc-500"
										>
											{post.data.pubDate.toLocaleDateString("en-EU", {
												month: "short",
												year: "numeric",
											})}
										</time>
									</div>
									<p class="mt-1 text-sm text-zinc-400 [.light_&]:text-zinc-600">
										{post.data.description}
									</p>
								</a>
							</li>
						))}
					</ul>
					<a href="/blog" class="mt-2 block text-sm text-zinc-500 transition-colors hover:text-zinc-300 [.light_&]:hover:text-zinc-700">
						All articles &rarr;
					</a>
				</section>
			)}
		</main>
	<Footer />
</BaseLayout>
