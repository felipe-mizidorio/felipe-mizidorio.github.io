---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { publications } from "../../data/publications";

const sorted = [...publications].sort((a, b) => b.year - a.year);
---

<BaseLayout title="Publications | Felipe Mizidorio" description="Academic publications and research papers.">
    <Header />
    <main class="mx-auto max-w-3xl px-6 py-20">
        <h1 class="text-3xl font-bold">Publications</h1>
        <p class="mt-2 text-zinc-400 [.light_&]:text-zinc-600">
            Academic papers and research publications.
        </p>

        {sorted.length == 0 && (
            <p class="mt-8 text-zinc-400">No publications yet.</p>
        )}

        <ul class="mt-12 divide-y divide-zinc-800 [.light_&].divide-zinc-200">
            {sorted.map((pub) => (
                <li class="py-6 first:pt-0">
                    <span class="text-sm text-zinc-500">{pub.year}</span>
                    <h2 class="mt-1 text-xl font-semibold">{pub.title}</h2>
                    <p class="mt-1 text-sm text-zinc-400 [.light_&]:text-zinc-600">
                        {pub.authors.join(", ")}
                    </p>
                    <p class="mt-1 text-sm italic text-zinc-500">{pub.venue}</p>

                    {pub.abstract && (
                        <p class="mt-3 text-sm text-zinc-400 [.light_&]:text-zinc-600">
                            {pub.abstract}
                        </p>
                    )}

                    {pub.tags && pub.tags.length > 0 && (
                        <div class="mt-2 flex gap-2">
                            {pub.tags.map((tag) => (
                                <span class="text-xs text-zinc-500">#{tag}</span>
                            ))}
                        </div>
                    )}

                    <div class="mt-3 flex gap-4">
                        {pub.doi && (
                            <a
                                href={`https://doi.org/${pub.doi}`}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-sm text-accent hover:underline"
                            >
                                DOI
                            </a>
                        )}
                        {pub.pdfUrl && (
                            <a
                                href={pub.pdfUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-sm text-accent hover:underline"
                            >
                                PDF
                            </a>
                        )}
                    </div>
                </li>
            ))}
        </ul>
    </main>
    <Footer />
</BaseLayout>