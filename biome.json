{
    "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
    "organizeImports": {
        "enabled": true
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 2
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "files": {
        "ignore": ["node_modules", "dist", ".astro", "*.astro"]
    }
}